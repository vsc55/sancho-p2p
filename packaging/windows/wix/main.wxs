<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom jpackage WiX template (based on the jpackage 25 / WiX 6 default). One
  addition over the stock template: a "SanchoAssociations" component group whose
  components are conditioned on the REGISTERASSOC property, so the installer can
  optionally register the .torrent / ed2k / magnet / sig2dat associations (the
  checkbox on the shortcut-prompt dialog, or REGISTERASSOC=0 for silent installs).

  Everything else mirrors the stock jpackage template; keep it in sync if the CI
  JDK (hence the jpackage WiX template) changes. jpackage generates it with an
  explicit ns0: prefix; the default namespace used here is equivalent.

  WiX 4+ syntax notes vs. the previous WiX 3 version of this file: <Product> and
  its inner <Package> merged into one <Package>; a Component's <Condition> child
  became the Condition attribute; Guid="*" is now the default (auto GUID);
  CustomAction uses BinaryRef (was BinaryKey); <Custom> conditions moved from
  element text to the Condition attribute.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <?ifdef JpIsSystemWide ?>
    <?define JpInstallScope="perMachine"?>
  <?else ?>
    <?define JpInstallScope="perUser"?>
  <?endif ?>

  <?define JpProductLanguage=1033 ?>
  <?define JpInstallerVersion=200 ?>
  <?define JpCompressedMsi=yes ?>

  <?include $(var.JpConfigDir)/overrides.wxi ?>

  <?ifdef JpAllowUpgrades ?>
    <?define JpUpgradeVersionOnlyDetectUpgrade="no"?>
  <?else ?>
    <?define JpUpgradeVersionOnlyDetectUpgrade="yes"?>
  <?endif ?>
  <?ifdef JpAllowDowngrades ?>
    <?define JpUpgradeVersionOnlyDetectDowngrade="no"?>
  <?else ?>
    <?define JpUpgradeVersionOnlyDetectDowngrade="yes"?>
  <?endif ?>

  <Package
      Name="$(var.JpAppName)"
      Language="$(var.JpProductLanguage)"
      Version="$(var.JpAppVersion)"
      Manufacturer="$(var.JpAppVendor)"
      UpgradeCode="$(var.JpProductUpgradeCode)"
      InstallerVersion="$(var.JpInstallerVersion)"
      Compressed="$(var.JpCompressedMsi)"
      ProductCode="$(var.JpProductCode)"
      Scope="$(var.JpInstallScope)">

    <SummaryInformation Manufacturer="$(var.JpAppVendor)" Description="$(var.JpAppDescription)" />

    <Media Id="1" Cabinet="Data.cab" EmbedCab="yes" />

    <Upgrade Id="$(var.JpProductUpgradeCode)">
      <UpgradeVersion
          OnlyDetect="$(var.JpUpgradeVersionOnlyDetectUpgrade)"
          Property="JP_UPGRADABLE_FOUND"
          Maximum="$(var.JpAppVersion)"
          MigrateFeatures="yes"
          IncludeMaximum="$(var.JpUpgradeVersionOnlyDetectUpgrade)" />
      <UpgradeVersion
          OnlyDetect="$(var.JpUpgradeVersionOnlyDetectDowngrade)"
          Property="JP_DOWNGRADABLE_FOUND"
          Minimum="$(var.JpAppVersion)"
          MigrateFeatures="yes"
          IncludeMinimum="$(var.JpUpgradeVersionOnlyDetectDowngrade)" />
    </Upgrade>

    <?ifndef JpAllowUpgrades ?>
    <CustomAction Id="JpDisallowUpgrade" Error="!(loc.DisallowUpgradeErrorMessage)" />
    <?endif ?>
    <?ifndef JpAllowDowngrades ?>
    <CustomAction Id="JpDisallowDowngrade" Error="!(loc.DowngradeErrorMessage)" />
    <?endif ?>

    <Binary Id="JpCaDll" SourceFile="wixhelper.dll" />

    <CustomAction Id="JpFindRelatedProducts" BinaryRef="JpCaDll" DllEntry="FindRelatedProductsEx" />

    <Feature Id="DefaultFeature" Title="!(loc.MainFeatureTitle)" Level="1">
      <ComponentGroupRef Id="Shortcuts" />
      <ComponentGroupRef Id="Files" />
      <ComponentGroupRef Id="FileAssociations" />
      <ComponentGroupRef Id="FragmentOsCondition" />
      <!-- Association registry components; each is conditioned on REGISTERASSOC. -->
      <ComponentGroupRef Id="SanchoAssociations" />
    </Feature>

    <!-- Whether to register .torrent + ed2k/magnet/sig2dat associations. Default on.
         A checkbox on the shortcut-prompt dialog toggles it interactively; for a
         silent/unattended install set it on the command line:
           msiexec /i sancho-*.msi /qn REGISTERASSOC=0   (0 = do not register)
         The association components (below) are conditioned on REGISTERASSOC=1. -->
    <Property Id="REGISTERASSOC" Value="1" Secure="yes" />

    <CustomAction Id="JpSetARPINSTALLLOCATION" Property="ARPINSTALLLOCATION" Value="[INSTALLDIR]" />
    <CustomAction Id="JpSetARPCOMMENTS" Property="ARPCOMMENTS" Value="$(var.JpAppDescription)" />
    <CustomAction Id="JpSetARPCONTACT" Property="ARPCONTACT" Value="$(var.JpAppVendor)" />
    <CustomAction Id="JpSetARPSIZE" Property="ARPSIZE" Value="$(var.JpAppSizeKb)" />

    <?ifdef JpHelpURL ?>
      <CustomAction Id="JpSetARPHELPLINK" Property="ARPHELPLINK" Value="$(var.JpHelpURL)" />
    <?endif ?>

    <?ifdef JpAboutURL ?>
      <CustomAction Id="JpSetARPURLINFOABOUT" Property="ARPURLINFOABOUT" Value="$(var.JpAboutURL)" />
    <?endif ?>

    <?ifdef JpUpdateURL ?>
      <CustomAction Id="JpSetARPURLUPDATEINFO" Property="ARPURLUPDATEINFO" Value="$(var.JpUpdateURL)" />
    <?endif ?>

    <?ifdef JpIcon ?>
    <Property Id="ARPPRODUCTICON" Value="JpARPPRODUCTICON" />
    <Icon Id="JpARPPRODUCTICON" SourceFile="$(var.JpIcon)" />
    <?endif ?>

    <UIRef Id="JpUI" />

    <InstallExecuteSequence>
      <Custom Action="JpSetARPINSTALLLOCATION" After="CostFinalize" Condition="Not Installed" />
      <Custom Action="JpSetARPCOMMENTS" After="CostFinalize" Condition="Not Installed" />
      <Custom Action="JpSetARPCONTACT" After="CostFinalize" Condition="Not Installed" />
      <Custom Action="JpSetARPSIZE" After="CostFinalize" Condition="Not Installed" />
      <?ifdef JpHelpURL ?>
        <Custom Action="JpSetARPHELPLINK" After="CostFinalize" Condition="Not Installed" />
      <?endif ?>
      <?ifdef JpAboutURL ?>
        <Custom Action="JpSetARPURLINFOABOUT" After="CostFinalize" Condition="Not Installed" />
      <?endif ?>
      <?ifdef JpUpdateURL ?>
        <Custom Action="JpSetARPURLUPDATEINFO" After="CostFinalize" Condition="Not Installed" />
      <?endif ?>

      <?ifndef JpAllowUpgrades ?>
      <Custom Action="JpDisallowUpgrade" After="JpFindRelatedProducts" Condition="JP_UPGRADABLE_FOUND" />
      <?endif ?>
      <?ifndef JpAllowDowngrades ?>
      <Custom Action="JpDisallowDowngrade" After="JpFindRelatedProducts" Condition="JP_DOWNGRADABLE_FOUND" />
      <?endif ?>
      <LaunchConditions Before="AppSearch" />
      <RemoveExistingProducts Before="CostInitialize" />
      <Custom Action="JpFindRelatedProducts" After="FindRelatedProducts" />
    </InstallExecuteSequence>

    <InstallUISequence>
      <Custom Action="JpFindRelatedProducts" After="FindRelatedProducts" />
    </InstallUISequence>

  </Package>

  <!-- Registry for the optional associations. HKMU resolves to HKLM for a
       per-machine install. Each component carries the REGISTERASSOC condition, so
       clearing the checkbox (or REGISTERASSOC=0) installs the app without touching
       the shell associations. -->
  <Fragment>
    <ComponentGroup Id="SanchoAssociations">

      <!-- .torrent file extension -> "bittorrent" ProgId. ForceDeleteOnUninstall
           removes the whole key tree on uninstall so nothing is left behind. -->
      <Component Id="SanchoAssocTorrent" Directory="INSTALLDIR" Condition='REGISTERASSOC = "1"'>
        <RegistryKey Root="HKMU" Key="Software\Classes\.torrent" ForceDeleteOnUninstall="yes">
          <RegistryValue Value="bittorrent" Type="string" KeyPath="yes"/>
        </RegistryKey>
        <RegistryKey Root="HKMU" Key="Software\Classes\bittorrent" ForceDeleteOnUninstall="yes">
          <RegistryValue Value="TORRENT File" Type="string"/>
          <RegistryValue Key="shell" Value="open" Type="string"/>
          <RegistryValue Key="shell\open\command" Value="&quot;[INSTALLDIR]sancho.exe&quot; &quot;-l&quot; &quot;%1&quot;" Type="string"/>
        </RegistryKey>
      </Component>

      <!-- ed2k: URL protocol -->
      <Component Id="SanchoAssocEd2k" Directory="INSTALLDIR" Condition='REGISTERASSOC = "1"'>
        <RegistryKey Root="HKMU" Key="Software\Classes\ed2k" ForceDeleteOnUninstall="yes">
          <RegistryValue Value="URL: ed2k Protocol" Type="string" KeyPath="yes"/>
          <RegistryValue Name="URL Protocol" Value="" Type="string"/>
          <RegistryValue Key="shell\open\command" Value="&quot;[INSTALLDIR]sancho.exe&quot; &quot;-l&quot; &quot;%1&quot;" Type="string"/>
        </RegistryKey>
      </Component>

      <!-- magnet: URL protocol -->
      <Component Id="SanchoAssocMagnet" Directory="INSTALLDIR" Condition='REGISTERASSOC = "1"'>
        <RegistryKey Root="HKMU" Key="Software\Classes\magnet" ForceDeleteOnUninstall="yes">
          <RegistryValue Value="URL: magnet Protocol" Type="string" KeyPath="yes"/>
          <RegistryValue Name="URL Protocol" Value="" Type="string"/>
          <RegistryValue Key="shell\open\command" Value="&quot;[INSTALLDIR]sancho.exe&quot; &quot;-l&quot; &quot;%1&quot;" Type="string"/>
        </RegistryKey>
      </Component>

      <!-- sig2dat: URL protocol -->
      <Component Id="SanchoAssocSig2dat" Directory="INSTALLDIR" Condition='REGISTERASSOC = "1"'>
        <RegistryKey Root="HKMU" Key="Software\Classes\sig2dat" ForceDeleteOnUninstall="yes">
          <RegistryValue Value="URL: sig2dat Protocol" Type="string" KeyPath="yes"/>
          <RegistryValue Name="URL Protocol" Value="" Type="string"/>
          <RegistryValue Key="shell\open\command" Value="&quot;[INSTALLDIR]sancho.exe&quot; &quot;-l&quot; &quot;%1&quot;" Type="string"/>
        </RegistryKey>
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>
